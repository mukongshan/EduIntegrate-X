# 示例 .env.example
# 复制为 `.env` 后填写真实值；不要提交 `.env`

# 应用基础配置
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=changeme
LOG_LEVEL=INFO

# 前端真实联调配置
VITE_USE_MOCK=false
VITE_API_URL_A=http://localhost:8000
VITE_API_URL_B=http://localhost:8001
VITE_API_URL_C=http://localhost:8002
VITE_API_URL_INTEGRATION=http://localhost:8081
VITE_INTEGRATION_API_KEY=integration-server-api-key-2026

# 集成服务器配置
DB_PATH=./tmp/integration_server_demo.db
COLLEGE_A_URL=http://localhost:8000
COLLEGE_B_URL=http://localhost:8001
COLLEGE_C_URL=http://localhost:8002
API_KEY=integration-server-api-key-2026

# 学院 A 运行模式
COLLEGE_A_STORAGE=mock
USE_MOCK_EXTERNALS=true
COLLEGE_ID=A
INTEGRATION_HOST=http://localhost:8081

# 学院 B 运行模式
COLLEGE_B_STORAGE=mock
COLLEGE_B_ID=B
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=

# 真实 SQL Server 测试开关
RUN_SQLSERVER_TESTS=0

# 学院 A SQL Server
# 二选一：
# 1. 用实例名：MSSQL_SERVER=localhost\SQLEXPRESS
# 2. 用主机+端口：MSSQL_HOST=localhost 和 MSSQL_PORT=1433
MSSQL_SERVER=
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_TRUSTED_CONNECTION=true
MSSQL_USER=
MSSQL_PASSWORD=

# 可选：单独指定真实写库测试数据库
COLLEGE_A_TEST_DATABASE=

# 学院 C 运行模式
COLLEGE_C_STORAGE=mock
COLLEGE_C_ID=C
COLLEGE_C_PORT=8002

# 真实 MySQL 测试开关
RUN_MYSQL_TESTS=0

# 学院 C MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4

# 可选：单独指定真实写库测试数据库
COLLEGE_C_TEST_DATABASE=
